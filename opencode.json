{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["google-vertex", "openrouter"],
  "permission": {
    "external_directory": {
      "/private/var/folders/**": "allow",
      "/var/folders/**": "allow"
    }
  },
  "agent": {
    "general": {
      "model": "opencode-go/minimax-m3",
      "temperature": 0.7
    },
    "refactor": {
      "model": "opencode-go/minimax-m3",
      "temperature": 1
    }
  }
}
